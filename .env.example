# Machine-specific configuration for jrnew's dotfiles
# Copy this file to .env and customize for your machine
#
# These variables allow the same dotfiles and templates to work
# across different machines with different directory structures.

# ============================================================================
# PROJECTS
# ============================================================================

# Where your projects live
# This machine: E:/dev/projects
# Other machines: ~/projects, /workspace, etc.
PROJECTS_ROOT="E:/dev/projects"

# Where project templates are stored
TEMPLATES_DIR="$HOME/templates"

# ============================================================================
# VAULTS & DOCUMENTATION
# ============================================================================

# Where your Obsidian vaults are stored
VAULTS_DIR="E:/vaults"

# Personal documentation directory
DOCS_DIR="$HOME/docs"

# ============================================================================
# TOOLS & UTILITIES
# ============================================================================

# Development tools directory
TOOLS_DIR="E:/dev/tools"

# ============================================================================
# BACKUPS
# ============================================================================

# Where backup files are stored
BACKUP_DIR="${BACKUP_DIR:-E:/Security/v1-backups}"

# ============================================================================
# NOTES
# ============================================================================
#
# Setting these on a new machine:
# 1. cp .env.example .env
# 2. Edit .env with your actual paths
# 3. Restart your shell
#
# All scripts (newproject, navigation functions, etc.) will
# automatically use these values with sensible defaults.
